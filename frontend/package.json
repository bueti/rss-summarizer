{
	"name": "rss-summarizer-frontend",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"generate:api": "tsx scripts/generate-api-client.ts",
		"dev": "npm run generate:api && vite dev",
		"build": "npm run generate:api && vite build",
		"build:docker": "vite build",
