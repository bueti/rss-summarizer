		"@tailwindcss/postcss": "^4.1.18",
		"@tailwindcss/typography": "^0.5.19",
		"autoprefixer": "^10.4.23",
		"orval": "^7.17.2",
		"postcss": "^8.5.6",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.1.18",
		"tsx": "^4.21.0",
		"typescript": "^5.0.0",
		"vite": "^6.0.0"
	},
	"type": "module",
	"dependencies": {
