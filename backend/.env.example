# Database
DATABASE_URL=postgres://rss_user:rss_pass@localhost:5432/rss_summarizer?sslmode=disable

# Server
PORT=8080
ENV=development

# LLM (Anthropic Claude API)
LLM_API_URL=https://api.anthropic.com/v1/messages
LLM_API_KEY=your-anthropic-api-key-here
LLM_MODEL=claude-haiku-4-5

# Temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default

# Development Auth (bypass mode)
DEV_MODE=true
DEV_USER_ID=00000000-0000-0000-0000-000000000001

# Google OAuth (required when DEV_MODE=false)
# Get credentials from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback
SESSION_DURATION=720h  # 30 days

# Encryption (MUST be exactly 32 bytes for AES-256)
# Generate with: openssl rand -base64 32 | head -c 32
ENCRYPTION_KEY=CHANGE_ME_32_BYTES_EXACTLY_HERE
