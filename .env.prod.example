# Database Configuration
POSTGRES_DB=rss_summarizer
POSTGRES_USER=rss_user
POSTGRES_PASSWORD=change_me_to_secure_password

# GitHub Container Registry
# Replace with your GitHub username/org and repo name (lowercase)
# Example: bbu/rss-summarizer
GITHUB_REPOSITORY=your-username/rss-summarizer

# Application Configuration
ORIGIN=http://your-tailscale-ip:3000
FRONTEND_URL=http://your-tailscale-ip:3000
PUBLIC_API_URL=http://your-tailscale-ip:8080

# LLM Configuration
LLM_API_KEY=your_openai_or_anthropic_key
LLM_API_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4

# Encryption Key (must be exactly 32 bytes for AES-256)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your_32_byte_base64_encoded_key_here
